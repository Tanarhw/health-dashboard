# Whoop — get from developer.whoop.com
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/auth/whoop/callback

# Strava — get from strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

# Garmin Connect credentials (no dev account needed)
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Change this to a random string in production
SECRET_KEY=changeme-use-random-string-in-prod
